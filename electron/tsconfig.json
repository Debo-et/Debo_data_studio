{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "../dist-electron",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",          // ← change from "node16" to "node"
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0"          // ← suppress deprecation warning
  },
  "include": ["**/*"],
  "exclude": ["node_modules"]
}